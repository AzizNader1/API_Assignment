                "type": "object",
                "properties": {
                  "UserName": {
                    "type": "string"
                  },
                  "ExceptionStartDate": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "ExceptionEndDate": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "encoding": {
                "UserName": {
                  "style": "form"
                },
                "ExceptionStartDate": {
                  "style": "form"
                },
                "ExceptionEndDate": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
