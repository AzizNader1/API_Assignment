{
  "openapi": "3.0.4",
  "info": {
    "title": "API Assignment",
    "description": "API for managing exceptions, attendance, and loans",
    "version": "v1"
  },
  "paths": {
    "/api/Accounts/Login": {
      "post": {
        "tags": [
          "Accounts"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginUserDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginUserDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginUserDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/AddException": {
      "post": {
        "tags": [
          "Exceptions"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "ExceptionEndDate",
                  "ExceptionStartDate",
                  "UserName"
                ],
                "type": "object",
                "properties": {
                  "UserName": {
                    "maxLength": 100,
                    "type": "string"
                  },
                  "ExceptionStartDate": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "ExceptionEndDate": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "encoding": {
                "UserName": {
                  "style": "form"
                },
                "ExceptionStartDate": {
                  "style": "form"
                },
                "ExceptionEndDate": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/ReturnExceptions": {
      "get": {
        "tags": [
          "Exceptions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/ReturnMyExceptions": {
      "get": {
        "tags": [
          "Exceptions"
        ],
        "parameters": [
          {
            "name": "UserName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ExceptionStartDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "ExceptionEndDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/AddAttendance": {
      "post": {
        "tags": [
          "Exceptions"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "AttendanceDate",
                  "AttendanceType",
                  "Latitude",
                  "Longitude",
                  "UserName"
                ],
                "type": "object",
                "properties": {
                  "UserName": {
                    "maxLength": 100,
                    "type": "string"
                  },
                  "AttendanceDate": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "Longitude": {
                    "maximum": 1.7976931348623157E+308,
                    "minimum": 0.01,
                    "type": "number",
                    "format": "double"
                  },
                  "Latitude": {
                    "maximum": 1.7976931348623157E+308,
                    "minimum": 0.01,
                    "type": "number",
                    "format": "double"
                  },
                  "AttendanceType": {
                    "$ref": "#/components/schemas/AttendanceTypes"
                  }
                }
              },
              "encoding": {
                "UserName": {
                  "style": "form"
                },
                "AttendanceDate": {
                  "style": "form"
                },
                "Longitude": {
                  "style": "form"
                },
                "Latitude": {
                  "style": "form"
                },
                "AttendanceType": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/AddLoans": {
      "post": {
        "tags": [
          "Exceptions"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Amount",
                  "Installments",
                  "Notes",
                  "UserName"
                ],
                "type": "object",
                "properties": {
                  "UserName": {
                    "maxLength": 100,
                    "type": "string"
                  },
                  "Amount": {
                    "maximum": 1.7976931348623157E+308,
                    "minimum": 0.01,
                    "type": "number",
                    "format": "double"
                  },
                  "Installments": {
                    "maximum": 2147483647,
                    "minimum": 1,
                    "type": "integer",
                    "format": "int32"
                  },
                  "Notes": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "UserName": {
                  "style": "form"
                },
                "Amount": {
                  "style": "form"
                },
                "Installments": {
                  "style": "form"
                },
                "Notes": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/ReturnMyLoans": {
      "get": {
        "tags": [
          "Exceptions"
        ],
        "parameters": [
          {
            "name": "userName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/ReturnMyApprovals": {
      "get": {
        "tags": [
          "Exceptions"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Exceptions/ApproveExceptions": {
      "put": {
        "tags": [
          "Exceptions"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "ExceptionId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Status": {
                    "$ref": "#/components/schemas/ExceptionStatus"
                  }
                }
              },
              "encoding": {
                "ExceptionId": {
                  "style": "form"
                },
                "Status": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AttendanceTypes": {
        "enum": [
          "IN",
          "OUT"
        ],
        "type": "string"
      },
      "ExceptionStatus": {
        "enum": [
          "YES",
          "NO"
        ],
        "type": "string"
      },
      "LoginUserDto": {
        "required": [
          "password",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "maxLength": 100,
            "minLength": 8,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme.\r\n\r\nEnter 'Bearer' [space] and then your token.\r\n\r\nExample: \"Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "tags": [
    {
      "name": "Accounts"
    },
    {
      "name": "Exceptions"
    }
  ]
}